# Get this from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-bot-token-here

# Database file path (SQLite)
DATABASE_PATH=./data/bot.db

# Premium price in Telegram Stars (XTR) for the in-app /upgrade flow
PREMIUM_STARS_PRICE=250

# Comma-separated Telegram user IDs that get admin access
ADMIN_IDS=123456789

# Max size (MB) for /mp3 and /video downloads (Telegram bot send limit ~50MB)
MAX_DOWNLOAD_MB=49

# Watchlist alert threshold: notify on price moves of this percent (premium)
GEM_ALERT_PERCENT=20

# /safegems auto-scan: minimum Safety score (0-100) a trending token must reach to be shown
GEM_SCAN_MIN_SAFETY=60

# "Narasi naik" alert (premium): fire when 24h volume rises by at least this % vs baseline
GEM_VOLUME_SURGE_PERCENT=100
# ...and holder count rises by at least this % vs baseline
GEM_HOLDER_SURGE_PERCENT=15
# Minimum hours between narrative alerts for the same token (anti-spam)
GEM_NARRATIVE_COOLDOWN_HOURS=6

# --- Stripe (optional, for card subscriptions) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Public URL where Stripe redirects after checkout
PUBLIC_BASE_URL=https://yourdomain.com
